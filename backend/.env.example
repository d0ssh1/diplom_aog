# Diplom3D Environment Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=Diplom3D
DEBUG=True

# Database
# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/diplom3d
# SQLite (easier for local dev)
DATABASE_URL=sqlite+aiosqlite:///./diplom3d.db

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=["png","jpg","jpeg"]

# Image Processing
MIN_IMAGE_RESOLUTION=1000
DEFAULT_FLOOR_HEIGHT=3.0
